pushd "%~dp0"
if not exist logs mkdir logs
for /f "usebackq tokens=*" %%I in (`powershell -NoProfile -Command "(Get-Date).ToString('yyyyMMdd_HHmmss')"`) do set TS=%%I
if "%TS%"=="" set TS=unknown
set LOG=%CD%\logs\stlink_%TS%.log

echo ============================================================
echo   G071_NUCELO_CommBench  ST-Link (SWD) Flash
echo   Log: %LOG%
echo ============================================================
echo.

powershell -NoProfile -ExecutionPolicy Bypass -File "%~dp0program.ps1" -LogPath "%LOG%" -Pause %*
set RC=%ERRORLEVEL%

echo.
echo ============================================================
echo  Finished. Exit code = %RC%
echo  Press any key to close . . .
echo ============================================================
pause >nul
popd
exit /b %RC%
